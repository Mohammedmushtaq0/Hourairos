<!DOCTYPE html>
<html>
<head>

    <title>Hourairos Dashboard</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial,sans-serif;
        }

        body{
            background:#0b1020;
            color:white;
            min-height:100vh;
            padding:40px;
        }

        .container{
            max-width:1000px;
            margin:auto;
        }

        .card{
            background:#121933;
            border:1px solid #222b4a;
            border-radius:16px;
            padding:24px;
            margin-bottom:24px;
        }

        h1{
            font-size:32px;
            margin-bottom:10px;
        }

        p{
            color:#b9c0d3;
        }

        .logout-btn{
            margin-top:20px;
            display:inline-block;
            padding:12px 18px;
            background:#ff4d4d;
            color:white;
            text-decoration:none;
            border-radius:10px;
        }

        .section-title{
            margin-bottom:20px;
            font-size:24px;
        }

        .input-group{
            margin-bottom:20px;
        }

        label{
            display:block;
            margin-bottom:8px;
            color:#d7def0;
        }

        input{
            width:100%;
            padding:14px;
            border:none;
            border-radius:10px;
            background:#1a2342;
            color:white;
            font-size:15px;
        }

        .deploy-btn{
            margin-top:20px;
            width:100%;
            padding:16px;
            border:none;
            border-radius:12px;
            background:#4f7cff;
            color:white;
            font-size:16px;
            cursor:pointer;
            font-weight:bold;
        }

        .deploy-btn:hover{
            opacity:0.9;
        }

        .info-box{
            margin-top:20px;
            padding:18px;
            border-radius:12px;
            background:#0f1630;
            border:1px solid #28355e;
        }

        .info-box p{
            margin-bottom:10px;
        }

        .badge{
            display:inline-block;
            background:#1e8f4d;
            color:white;
            padding:6px 10px;
            border-radius:999px;
            font-size:12px;
            margin-top:10px;
        }

        .deployment-card{
            background:#0f1630;
            border:1px solid #28355e;
            border-radius:12px;
            padding:16px;
            margin-bottom:16px;
        }

        .deployment-id{
            font-weight:bold;
            margin-bottom:10px;
            color:white;
        }

        .deployment-link{
            color:#7ca6ff;
            word-break:break-all;
            text-decoration:none;
        }

        .deployment-link:hover{
            text-decoration:underline;
        }

        .deployment-date{
            margin-top:10px;
            font-size:13px;
            color:#8f9abc;
        }

        .empty-state{
            color:#8f9abc;
            text-align:center;
            padding:20px;
        }

    </style>

</head>

<body>

<div class="container">

    <div class="card">

        <h1>
            Welcome <%= userInfo.email %>
        </h1>

        <p>
            You are successfully authenticated with AWS Cognito.
        </p>

        <a href="/logout" class="logout-btn">
            Logout
        </a>

    </div>

    <div class="card">

        <h2 class="section-title">
            Deploy Static Website
        </h2>

        <form
            action="/deploy"
            method="POST"
            enctype="multipart/form-data"
        >

            <div class="input-group">

                <label>
                    Website Name
                </label>

                <input
                    type="text"
                    name="websiteName"
                    placeholder="my-awesome-site"
                    required
                >

            </div>

            <div class="input-group">

                <label>
                    Upload ZIP File
                </label>

                <input
                    type="file"
                    name="websiteZip"
                    accept=".zip"
                    required
                >

            </div>

            <button class="deploy-btn">
                Deploy Website
            </button>

        </form>

        <div class="info-box">

            <p>
                Upload a ZIP file containing your static website.
            </p>

            <p>
                Supported:
                HTML, CSS, JS, Images
            </p>

            <div class="badge">
                CloudFront + S3 Deployment Engine
            </div>

        </div>

    </div>

    <div class="card">

        <h2 class="section-title">
            Deployment History
        </h2>

        <% if (deployments && deployments.length > 0) { %>

            <% deployments.forEach(deployment => { %>

                <div class="deployment-card">

                    <div class="deployment-id">
                        <%= deployment.deploymentId %>
                    </div>

                    <a
                        href="<%= deployment.deploymentUrl %>"
                        target="_blank"
                        class="deployment-link"
                    >
                        <%= deployment.deploymentUrl %>
                    </a>

                    <div class="deployment-date">
    Created:
    <%= deployment.createdAt %>
</div>

<form
    action="/delete-deployment/<%= deployment.deploymentId %>"
    method="POST"
    style="margin-top:12px;"
>

    <button
        type="submit"
        style="
            background:#ff4d4d;
            color:white;
            border:none;
            padding:10px 14px;
            border-radius:8px;
            cursor:pointer;
        "
    >
        Delete Deployment
    </button>

</form>

                </div>

            <% }) %>

        <% } else { %>

            <div class="empty-state">

                No deployments yet.

            </div>

        <% } %>

    </div>

</div>

</body>
</html>