{
  "family": "hourairous-app-fargate",
  "taskRoleArn": "arn:aws:iam::851725373663:role/hourairos-app-role",
  "executionRoleArn": "arn:aws:iam::851725373663:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "hourairos-app-fragate",
      "image": "851725373663.dkr.ecr.ap-south-1.amazonaws.com/hourairos/main-app:latest",
      "essential": true,
      "memory": 2048,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "name": "hourairos-app-fargate",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT",
          "value": "http://otel-collector:4318/v1/traces"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hourairous-app-fargate",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
